---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
  tags?: string[];
}

const { title, description, pubDate, heroImage, tags = [] } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | BoloDB Blog`} description={description} image={heroImage}>
  <article class="mx-auto max-w-3xl px-6 py-12">
    <header class="mb-8">
      {tags.length > 0 && (
        <div class="mb-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span
              class="rounded-full px-3 py-1 text-xs font-medium"
              style="background:var(--surface-2); color:var(--brand);"
            >
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="text-4xl font-bold tracking-tight" style="color:var(--ink);">{title}</h1>
      <time class="mt-3 block" style="color:var(--muted);">{formattedDate}</time>
      {heroImage && (
        <img src={heroImage} alt={title} class="mt-6 w-full rounded-lg" />
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
