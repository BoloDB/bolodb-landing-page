---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
  tags?: string[];
}

const { title, description, pubDate, heroImage, tags = [] } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | BoloDB Blog`} description={description} image={heroImage}>
  <article class="relative z-[2] mx-auto max-w-[720px] px-6 py-16 md:py-24">
    <header class="mb-12">
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 text-[13px] font-medium transition-colors mb-8"
        style="color:var(--muted);"
        onmouseover="this.style.color='var(--brand)'"
        onmouseout="this.style.color='var(--muted)'"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M19 12H5"/><path d="m12 19-7-7 7-7"/>
        </svg>
        Back to blog
      </a>

      {tags.length > 0 && (
        <div class="mb-5 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span
              class="rounded-md px-2.5 py-1 text-[11px] font-semibold tracking-[0.04em]"
              style="background:rgba(var(--glow-rgb),0.1); color:var(--brand);"
            >
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1
        class="text-balance font-extrabold leading-[1.1]"
        style="font-size:clamp(2rem,4.5vw,3rem); letter-spacing:-0.03em; color:var(--ink);"
      >
        {title}
      </h1>

      <div class="mt-5 flex items-center gap-3">
        <div
          class="flex h-8 w-8 items-center justify-center rounded-full text-[13px] font-bold"
          style="background:rgba(var(--glow-rgb),0.12); color:var(--brand);"
        >
          B
        </div>
        <div class="flex flex-col">
          <span class="text-[13px] font-medium" style="color:var(--ink-2);">BoloDB Team</span>
          <time class="text-[12px]" style="color:var(--faint); font-family:'JetBrains Mono',monospace;">
            {formattedDate}
          </time>
        </div>
      </div>

      {heroImage && (
        <img
          src={heroImage}
          alt={title}
          class="mt-8 w-full rounded-xl border"
          style="border-color:var(--border);"
        />
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <!-- Post footer -->
    <div class="mt-16 border-t pt-8" style="border-color:var(--border);">
      <div class="flex items-center justify-between">
        <a
          href="/blog"
          class="inline-flex items-center gap-1.5 text-[13px] font-medium transition-colors"
          style="color:var(--muted);"
          onmouseover="this.style.color='var(--brand)'"
          onmouseout="this.style.color='var(--muted)'"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M19 12H5"/><path d="m12 19-7-7 7-7"/>
          </svg>
          All posts
        </a>
        <a
          href="https://github.com/BoloDB/bolodb"
          class="inline-flex items-center gap-1.5 text-[13px] font-medium transition-colors"
          style="color:var(--muted);"
          onmouseover="this.style.color='var(--brand)'"
          onmouseout="this.style.color='var(--muted)'"
        >
          Star on GitHub
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
          </svg>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
