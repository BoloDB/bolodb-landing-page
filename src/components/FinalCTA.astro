---
---

<section class="relative z-[2] px-6 pb-[100px] pt-[60px]">
  <div
    data-reveal="1"
    class="relative mx-auto max-w-[1100px] overflow-hidden rounded-2xl border px-8 text-center"
    style={{
      borderColor: 'var(--border-2)',
      background: 'radial-gradient(900px 420px at 50% 120%, rgba(var(--glow-rgb),0.18) 0%, rgba(98,224,176,0.08) 40%, transparent 70%), var(--card-2)',
      padding: '96px 32px',
    }}
  >
    <!-- Glow blob -->
    <div
      aria-hidden="true"
      class="absolute bottom-[-140px] left-1/2 h-[280px] w-[520px] -translate-x-1/2"
      style={{
        background: 'radial-gradient(closest-side, rgba(139,123,255,0.3), transparent)',
        filter: 'blur(30px)',
        animation: 'breathe 6s ease-in-out infinite',
      }}
    ></div>

    <h2
      class="relative m-0 mx-auto text-balance font-extrabold leading-[1.05]"
      style="font-size:clamp(2.2rem,4.5vw,3.6rem); letter-spacing:-0.03em; color:var(--ink); max-width:580px;"
    >
      Ask your first question in a minute.
    </h2>
    <p
      class="relative mx-auto mt-5 max-w-[440px] text-[15px] leading-relaxed"
      style="color:var(--muted);"
    >
      No setup, no API keys — the AI is built in. Connect your database, or click once and explore the sample store database.
    </p>
    <div class="relative mt-8 flex flex-wrap justify-center" style="gap:12px;">
      <a
        href="https://app.bolodb.dev/signup"
        class="inline-flex items-center rounded-lg font-semibold transition-all"
        style={{
          background: 'var(--contrast-bg)',
          color: 'var(--contrast-ink)',
          fontSize: '15px',
          padding: '14px 28px',
          letterSpacing: '-0.01em',
        }}
        onmouseover="this.style.background='var(--brand)'; this.style.color='var(--on-brand)'; this.style.transform='translateY(-2px)'"
        onmouseout="this.style.background='var(--contrast-bg)'; this.style.color='var(--contrast-ink)'; this.style.transform='none'"
      >
        Start for free
      </a>
      <a
        href="#demo"
        class="inline-flex items-center rounded-lg font-medium transition-all"
        style={{
          background: 'transparent',
          color: 'var(--ink-2)',
          fontSize: '15px',
          padding: '14px 28px',
          border: '1px solid var(--border-2)',
        }}
        onmouseover="this.style.borderColor='var(--muted)'; this.style.color='var(--ink)'; this.style.transform='translateY(-2px)'"
        onmouseout="this.style.borderColor='var(--border-2)'; this.style.color='var(--ink-2)'; this.style.transform='none'"
      >
        Try with sample data
      </a>
    </div>
  </div>
</section>
