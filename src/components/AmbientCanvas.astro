---
---

<canvas id="ambient-canvas" aria-hidden="true" style="position:fixed; inset:0; width:100vw; height:100vh; z-index:0; pointer-events:none"></canvas>

<script is:inline>
(function () {
  const canvas = document.getElementById('ambient-canvas');
  if (!canvas) return;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const ctx = canvas.getContext('2d');
  const dpr = Math.min(1.5, devicePixelRatio || 1);
  let w, h;
  const resize = () => {
    w = canvas.width = innerWidth * dpr;
    h = canvas.height = innerHeight * dpr;
  };
  resize();
  addEventListener('resize', resize);
  const isDark = () => document.documentElement.getAttribute('data-theme') !== 'light';
  const CD = [[77, 166, 255], [98, 224, 176], [139, 123, 255]];
  const CL = [[27, 158, 107], [43, 179, 214], [95, 140, 220]];
  const blobs = [
    { x: 0.2, y: 0.15, r: 0.5, ci: 0, ax: 0.05, ay: 0.06, sp: 0.00013, ph: 0 },
    { x: 0.82, y: 0.12, r: 0.45, ci: 1, ax: 0.06, ay: 0.05, sp: 0.00017, ph: 2 },
    { x: 0.55, y: 0.8, r: 0.55, ci: 2, ax: 0.07, ay: 0.05, sp: 0.00011, ph: 4 },
  ];
  const N = 70;
  const parts = Array.from({ length: N }, () => ({
    x: Math.random() * innerWidth,
    y: Math.random() * innerHeight,
    vx: (Math.random() - 0.5) * 0.22,
    vy: (Math.random() - 0.5) * 0.22,
    r: Math.random() * 1.4 + 0.4,
  }));
  const draw = (t) => {
    ctx.clearRect(0, 0, w, h);
    ctx.globalCompositeOperation = 'lighter';
    const pal = isDark() ? CD : CL;
    const ba = isDark() ? 0.03 : 0.09;
    for (const b of blobs) {
      const cx = (b.x + Math.sin(t * b.sp + b.ph) * b.ax) * w;
      const cy = (b.y + Math.cos(t * b.sp * 1.3 + b.ph) * b.ay) * h;
      const rad = b.r * Math.max(w, h);
      const cc = pal[b.ci];
      const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, rad);
      g.addColorStop(0, 'rgba(' + cc[0] + ',' + cc[1] + ',' + cc[2] + ',' + ba + ')');
      g.addColorStop(1, 'rgba(' + cc[0] + ',' + cc[1] + ',' + cc[2] + ',0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, w, h);
    }
    ctx.globalCompositeOperation = 'source-over';
    ctx.save();
    ctx.scale(dpr, dpr);
    for (const p of parts) {
      p.x += p.vx;
      p.y += p.vy;
      if (p.x < 0) p.x = innerWidth;
      if (p.x > innerWidth) p.x = 0;
      if (p.y < 0) p.y = innerHeight;
      if (p.y > innerHeight) p.y = 0;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, 7);
      ctx.fillStyle = isDark() ? 'rgba(148,190,235,0.35)' : 'rgba(27,110,75,0.35)';
      ctx.fill();
    }
    for (let a = 0; a < N; a++)
      for (let b2 = a + 1; b2 < N; b2++) {
        const dx = parts[a].x - parts[b2].x;
        const dy = parts[a].y - parts[b2].y;
        const d2 = dx * dx + dy * dy;
        if (d2 < 9000) {
          ctx.beginPath();
          ctx.moveTo(parts[a].x, parts[a].y);
          ctx.lineTo(parts[b2].x, parts[b2].y);
          var rgb = isDark() ? '110,160,220' : '27,110,75';
          ctx.strokeStyle = 'rgba(' + rgb + ',' + (0.1 * (1 - d2 / 9000)) + ')';
          ctx.stroke();
        }
      }
    ctx.restore();
  };
  if (reduced) { draw(6000); return; }
  let animId;
  const loop = (now) => {
    if (!document.hidden) draw(now);
    animId = requestAnimationFrame(loop);
  };
  animId = requestAnimationFrame(loop);
})();
</script>
