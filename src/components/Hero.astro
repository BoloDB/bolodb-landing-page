---
const APP_URL = 'https://app.bolodb.dev';
---

<section class="bd-hero" data-screen-label="Hero">
  <div class="bd-hero__eyebrow">TEXT-TO-SQL FOR HUMANS</div>
  <h1 class="bd-hero__title">
    <span class="bd-hero__line bd-hero__line--1"><span>Ask your data.</span></span>
    <span class="bd-hero__line bd-hero__line--2"><span>Trust the answer.</span></span>
  </h1>
  <p class="bd-hero__subtitle">
    Plain-English questions in. Verified SQL, a readable explanation, and an honest confidence level out. Your
    rows never leave your database.
  </p>
  <div class="bd-hero__search-wrap">
    <div class="bd-hero__search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="M21 21l-4.3-4.3"></path>
      </svg>
      <div class="bd-hero__search-text"><span id="bd-hero-typed"></span><span class="bd-hero__caret">|</span></div>
      <span class="bd-hero__enter">↵</span>
    </div>
  </div>
  <div class="bd-hero__actions">
    <a href={APP_URL} class="bd-hero__primary">Start for free</a>
    <a href="#demo" class="bd-hero__secondary">Watch it work ↓</a>
  </div>
  <a href="#demo" class="bd-hero__scroll-cue" aria-label="Scroll to demo">
    <span class="bd-hero__scroll-cue-dot"></span>
  </a>
</section>

<style>
  .bd-hero {
    position: relative;
    z-index: 2;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: clamp(96px, 20vh, 150px) 24px clamp(48px, 10vh, 90px);
    gap: clamp(18px, 3.2vh, 34px);
  }
  .bd-hero__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    letter-spacing: 0.22em;
    color: var(--accent);
    animation: rise-in 0.6s cubic-bezier(0.22, 0.61, 0.36, 1) both;
  }
  .bd-hero__title {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .bd-hero__line {
    display: block;
    overflow: hidden;
  }
  .bd-hero__line--1 {
    animation: mask-up 0.8s cubic-bezier(0.22, 0.61, 0.36, 1) 0.1s both;
  }
  .bd-hero__line--2 {
    animation: mask-up 0.8s cubic-bezier(0.22, 0.61, 0.36, 1) 0.35s both;
  }
  .bd-hero__line span {
    display: block;
    font-size: clamp(1.6rem, 8.5vw, 6.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.035em;
    white-space: nowrap;
    color: var(--ink);
  }
  .bd-hero__line--2 span {
    background: var(--grad-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .bd-hero__subtitle {
    margin: 0;
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    line-height: 1.6;
    color: var(--muted);
    max-width: 560px;
    text-wrap: balance;
    animation: rise-in 0.6s cubic-bezier(0.22, 0.61, 0.36, 1) 0.6s both;
  }
  .bd-hero__search-wrap {
    width: min(620px, 100%);
    animation: rise-in 0.6s cubic-bezier(0.22, 0.61, 0.36, 1) 0.75s both;
  }
  .bd-hero__search {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 22px;
    background: var(--glass);
    border: 1px solid var(--border);
    border-radius: 99px;
    box-shadow: var(--shadow-lg), 0 0 0 1px rgba(var(--glow-rgb), 0.06);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .bd-hero__search-text {
    flex: 1;
    text-align: left;
    font-size: 16px;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
  }
  .bd-hero__caret {
    color: var(--brand);
    font-weight: 300;
    animation: blink 1s step-end infinite;
  }
  .bd-hero__enter {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--faint);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 3px 7px;
  }
  .bd-hero__actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    animation: rise-in 0.6s cubic-bezier(0.22, 0.61, 0.36, 1) 0.9s both;
  }
  .bd-hero__primary {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: var(--brand);
    color: var(--on-brand);
    font-weight: 700;
    font-size: 16px;
    padding: 16px 30px;
    border-radius: 99px;
    letter-spacing: -0.01em;
    box-shadow: 0 10px 32px -8px rgba(var(--glow-rgb), 0.45);
    transition: all 0.18s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .bd-hero__primary:hover {
    background: var(--brand-2);
    color: var(--on-brand);
    transform: translateY(-2px);
    box-shadow: 0 18px 44px -10px rgba(var(--glow-rgb), 0.55);
  }
  .bd-hero__secondary {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: transparent;
    color: var(--ink);
    font-weight: 600;
    font-size: 16px;
    padding: 16px 30px;
    border-radius: 99px;
    border: 1px solid var(--border-2);
    transition: all 0.18s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .bd-hero__secondary:hover {
    border-color: var(--muted);
    color: var(--ink);
    transform: translateY(-2px);
  }
  .bd-hero__primary:active {
    transform: translateY(0) scale(0.97);
    box-shadow: 0 6px 20px -8px rgba(var(--glow-rgb), 0.45);
  }
  .bd-hero__secondary:active {
    transform: translateY(0) scale(0.97);
  }

  .bd-hero__scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    width: 24px;
    height: 38px;
    border: 1.5px solid var(--border-2);
    border-radius: 99px;
    padding-top: 8px;
    opacity: 0;
    animation: rise-in 0.6s cubic-bezier(0.22, 0.61, 0.36, 1) 1.1s both;
    transition: border-color 0.2s;
  }
  .bd-hero__scroll-cue:hover {
    border-color: var(--brand);
  }
  .bd-hero__scroll-cue-dot {
    width: 4px;
    height: 8px;
    border-radius: 99px;
    background: var(--brand);
    animation: scrollCue 1.8s ease-in-out infinite;
  }
  @keyframes scrollCue {
    0% {
      opacity: 0;
      transform: translateY(0);
    }
    30% {
      opacity: 1;
    }
    70% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translateY(12px);
    }
  }

  @media (max-height: 720px), (max-width: 640px) {
    .bd-hero__scroll-cue {
      display: none;
    }
  }
</style>

<script>
  const HERO_QS = [
    'How many orders were completed last month?',
    'Which region grew fastest this quarter?',
    "What's our average order value by channel?",
  ];
  const el = document.getElementById('bd-hero-typed');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (el) {
    if (reduced) {
      el.textContent = HERO_QS[0];
    } else {
      let qi = 0;
      let i = 0;
      let dir = 1;
      const tick = () => {
        const q = HERO_QS[qi];
        if (dir === 1) {
          i++;
          el.textContent = q.slice(0, i);
          if (i >= q.length) {
            dir = -1;
            setTimeout(tick, 2200);
            return;
          }
          setTimeout(tick, 45);
        } else {
          i -= 3;
          if (i <= 0) {
            i = 0;
            dir = 1;
            qi = (qi + 1) % HERO_QS.length;
          }
          el.textContent = q.slice(0, Math.max(0, i));
          setTimeout(tick, dir === 1 ? 500 : 18);
        }
      };
      tick();
    }
  }
</script>
