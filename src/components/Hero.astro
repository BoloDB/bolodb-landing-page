---
---

<section class="relative overflow-hidden py-20 md:py-32">
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/5 to-transparent"></div>
    <div class="absolute left-1/2 top-0 -z-10 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/5 blur-3xl"></div>
  </div>
  <div class="mx-auto max-w-4xl px-6 text-center">
    <div class="mb-6 inline-flex items-center rounded-full border bg-secondary/50 px-4 py-1.5 text-sm text-secondary-foreground">
      <span class="mr-2 inline-block h-2 w-2 rounded-full bg-green-500"></span>
      Now in early access
    </div>
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl">
      The database that
      <span class="text-primary">scales with you</span>
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground md:text-xl">
      BoloDB is a modern, developer-friendly database built for today's applications.
      Simple to start, powerful when you need it.
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="https://app.bolodb.dev"
        class="inline-flex h-11 items-center justify-center rounded-md bg-primary px-8 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
      >
        Get Started Free
      </a>
      <a
        href="https://docs.bolodb.dev"
        class="inline-flex h-11 items-center justify-center rounded-md border px-8 text-sm font-medium transition-colors hover:bg-secondary"
      >
        Read the Docs
      </a>
    </div>
    <div class="mt-16 grid grid-cols-3 gap-8 border-t pt-8 text-center">
      <div>
        <div class="text-2xl font-bold">50ms</div>
        <div class="text-sm text-muted-foreground">Avg. response time</div>
      </div>
      <div>
        <div class="text-2xl font-bold">99.99%</div>
        <div class="text-sm text-muted-foreground">Uptime SLA</div>
      </div>
      <div>
        <div class="text-2xl font-bold">SOC 2</div>
        <div class="text-sm text-muted-foreground">Compliant</div>
      </div>
    </div>
  </div>
</section>
