---
---

<section
  id="hero"
  aria-labelledby="hero-title"
  class="relative z-[2] flex min-h-screen flex-col items-center justify-center px-6 pb-20 pt-[140px] text-center"
  style="gap:34px;"
>
  <div
    class="font-medium tracking-[0.22em] anim-rise-in anim-delay-1"
    style="font-family:'JetBrains Mono',monospace; font-size:12.5px; color:var(--accent);"
  >
    TEXT-TO-SQL FOR HUMANS
  </div>

  <h1 id="hero-title" class="m-0 flex flex-col" style="gap:2px;">
    <span class="block overflow-hidden" style="animation:maskUp 0.8s cubic-bezier(0.22,0.61,0.36,1) 0.1s both;">
      <span
        class="block whitespace-nowrap font-extrabold leading-[1.05]"
        style="font-size:clamp(2.5rem,7vw,6.5rem); letter-spacing:-0.035em; color:var(--ink);"
      >
        Ask your data.
      </span>
    </span>
    <span class="block overflow-hidden" style="animation:maskUp 0.8s cubic-bezier(0.22,0.61,0.36,1) 0.35s both;">
      <span
        class="block whitespace-nowrap bg-clip-text font-extrabold leading-[1.05] text-transparent"
        style="font-size:clamp(2.5rem,7vw,6.5rem); letter-spacing:-0.035em; background:var(--grad-text); -webkit-background-clip:text; background-clip:text;"
      >
        Trust the answer.
      </span>
    </span>
  </h1>

  <p
    class="m-0 max-w-[560px] text-balance anim-rise-in anim-delay-3"
    style="font-size:clamp(1.05rem,1.6vw,1.3rem); line-height:1.6; color:var(--muted);"
  >
    Plain-English questions in. Verified SQL, a readable explanation, and an honest confidence level out. Your rows never leave your database.
  </p>

  <!-- Typed search bar -->
  <div class="w-full max-w-[620px] anim-rise-in anim-delay-4">
    <div
      class="flex items-center rounded-full border"
      style="gap:14px; padding:18px 22px; background:var(--glass); border-color:var(--border); border-radius:99px; box-shadow:var(--shadow-lg), 0 0 0 1px rgba(var(--glow-rgb),0.06); backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px);"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="M21 21l-4.3-4.3"></path>
      </svg>
      <div id="hero-typed" class="flex-1 overflow-hidden text-left text-base" style="color:var(--ink); white-space:nowrap;">
        <span id="hero-typed-text"></span><span style="color:var(--brand); font-weight:300; animation:blink 1s step-end infinite;">|</span>
      </div>
      <span
        class="rounded-md border px-1.5 py-0.5 text-[11px]"
        style="font-family:'JetBrains Mono',monospace; color:var(--faint); border-color:var(--border);"
      >↵</span>
    </div>
  </div>

  <!-- CTAs -->
  <div class="flex flex-wrap justify-center anim-rise-in anim-delay-5" style="gap:14px;">
    <a
      href="https://app.bolodb.dev"
      class="inline-flex items-center rounded-full font-bold transition-all"
      style="gap:9px; background:var(--brand); color:var(--on-brand); font-size:16px; padding:16px 30px; letter-spacing:-0.01em; box-shadow:0 10px 32px -8px rgba(var(--glow-rgb),0.45);"
      onmouseover="this.style.background='var(--brand-2)'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 18px 44px -10px rgba(var(--glow-rgb),0.55)'"
      onmouseout="this.style.background='var(--brand)'; this.style.transform='none'; this.style.boxShadow='0 10px 32px -8px rgba(var(--glow-rgb),0.45)'"
    >
      Start for free
    </a>
    <a
      href="#demo"
      class="inline-flex items-center rounded-full font-semibold transition-all"
      style="gap:9px; background:transparent; color:var(--ink); font-size:16px; padding:16px 30px; border:1px solid var(--border-2);"
      onmouseover="this.style.borderColor='var(--muted)'; this.style.transform='translateY(-2px)'"
      onmouseout="this.style.borderColor='var(--border-2)'; this.style.transform='none'"
    >
      Watch it work ↓
    </a>
  </div>
</section>

<script is:inline>
(function () {
  const el = document.getElementById('hero-typed-text');
  if (!el) return;
  const qs = [
    'How many orders were completed last month?',
    'Which region grew fastest this quarter?',
    "What's our average order value by channel?",
  ];
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    el.textContent = qs[0];
    return;
  }
  let qi = 0, i = 0, dir = 1;
  function tick() {
    const q = qs[qi];
    if (dir === 1) {
      i++;
      el.textContent = q.slice(0, i);
      if (i >= q.length) {
        dir = -1;
        setTimeout(tick, 2200);
        return;
      }
      setTimeout(tick, 45);
    } else {
      i -= 3;
      if (i <= 0) {
        i = 0;
        dir = 1;
        qi = (qi + 1) % qs.length;
      }
      el.textContent = q.slice(0, Math.max(0, i));
      setTimeout(tick, dir === 1 ? 500 : 18);
    }
  }
  tick();
})();
</script>
