---
// BoloDB mark: a speech bubble (conversation) fused with a database cylinder.
// Theme-adaptive — the bubble uses --brand, the database --muted, and the disc
// gaps are knocked out with --bg so it reads on any surface. The opaque database
// fill sits in front of the bubble, matching the brand reference.
interface Props {
  size?: number;
  class?: string;
}
const { size = 24, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  class={className}
  role="img"
  aria-hidden="true"
>
  <!-- Speech bubble -->
  <path
    d="M14 7 L33 7 Q41 7 41 15 L41 26 Q41 34 33 34 L23 34 L15 43 L17 34 L14 34 Q6 34 6 26 L6 15 Q6 7 14 7 Z"
    stroke="var(--brand)"
    stroke-width="3.4"
    stroke-linejoin="round"
    fill="none"></path>
  <!-- Database cylinder (opaque fill knocks out the bubble line it overlaps) -->
  <g>
    <path d="M25.5 24 L25.5 48 A16.5 6 0 0 0 58.5 48 L58.5 24 Z" fill="var(--muted)"></path>
    <ellipse cx="42" cy="24" rx="16.5" ry="6" fill="var(--muted)"></ellipse>
    <path d="M25.5 24 A16.5 6 0 0 0 58.5 24" fill="none" stroke="var(--bg)" stroke-width="1.6" opacity="0.35"></path>
    <path d="M25.5 32 A16.5 6 0 0 0 58.5 32" fill="none" stroke="var(--bg)" stroke-width="2.6"></path>
    <path d="M25.5 40 A16.5 6 0 0 0 58.5 40" fill="none" stroke="var(--bg)" stroke-width="2.6"></path>
  </g>
</svg>
