---
import TrustFlip from './TrustFlip.tsx';
---

<section
  id="trust"
  aria-labelledby="trust-title"
  class="relative z-[2] mx-auto max-w-[1060px] px-6 py-[110px]"
>
  <div data-reveal="1" class="mb-[56px] flex flex-col" style="gap:14px;">
    <span
      class="text-xs tracking-[0.22em]"
      style="font-family:'JetBrains Mono',monospace; color:var(--brand);"
    >
      03 — TRUST
    </span>
    <h2
      id="trust-title"
      class="m-0 max-w-[620px] text-balance font-extrabold leading-[1.05]"
      style="font-size:clamp(2rem,4vw,3.2rem); letter-spacing:-0.03em; color:var(--ink);"
    >
      Trust you can verify, not vibes.
    </h2>
  </div>

  <div class="grid items-stretch" style="grid-template-columns:1.1fr 0.9fr; gap:24px;">
    <!-- Flip card -->
    <div data-reveal="2">
      <TrustFlip client:load />
    </div>

    <!-- Right column -->
    <div class="flex flex-col" style="gap:24px;">
      <!-- What reaches the AI -->
        <div data-reveal="3"
          class="flex flex-col rounded-[20px] border p-6.5"
          style="background:var(--card); border-color:var(--border); gap:14px;"
        >
        <span
          class="text-[11px] tracking-[0.14em]"
          style="font-family:'JetBrains Mono',monospace; color:var(--muted);"
        >
          WHAT REACHES THE AI
        </span>
        <svg viewBox="0 0 320 96" class="h-auto w-full" aria-hidden="true">
          <rect x="2" y="26" width="88" height="44" rx="10" fill="none" stroke="var(--border-2)"></rect>
          <text x="46" y="45" text-anchor="middle" fill="var(--ink-2)" font-size="11" font-family="Hanken Grotesk">Your DB</text>
          <text x="46" y="60" text-anchor="middle" fill="var(--faint)" font-size="9" font-family="JetBrains Mono">rows stay here</text>
          <path d="M 96 38 H 218" stroke="var(--brand)" stroke-width="1.5" stroke-dasharray="6 6" style="animation:dashFlow 1.2s linear infinite"></path>
          <text x="157" y="30" text-anchor="middle" fill="var(--brand)" font-size="9" font-family="JetBrains Mono">schema + question</text>
          <path d="M 96 60 H 150" stroke="#c75d4e" stroke-width="1.5" stroke-dasharray="4 5"></path>
          <text x="123" y="76" text-anchor="middle" fill="var(--low)" font-size="9" font-family="JetBrains Mono">rows ✕ never</text>
          <line x1="146" y1="52" x2="158" y2="68" stroke="#c75d4e" stroke-width="1.5"></line>
          <rect x="224" y="26" width="94" height="44" rx="10" fill="none" stroke="var(--border-2)"></rect>
          <text x="271" y="45" text-anchor="middle" fill="var(--ink-2)" font-size="11" font-family="Hanken Grotesk">Gemini AI</text>
          <text x="271" y="60" text-anchor="middle" fill="var(--faint)" font-size="9" font-family="JetBrains Mono">writes SQL only</text>
        </svg>
        <span class="text-[13.5px] leading-[1.6]" style="color:var(--muted);">
          Only your question, the schema, and a few sample values are sent — never bulk table contents, results, or credentials.
        </span>
      </div>

      <!-- Read-only + Local-first -->
      <div data-reveal="4" class="grid grid-cols-2" style="gap:24px;">
        <div
          class="flex flex-col rounded-[20px] border p-5.5"
          style="background:var(--card); border-color:var(--border); gap:8px;"
        >
          <span class="text-[26px] font-extrabold" style="letter-spacing:-0.02em; color:var(--ink);">
            Read-only
          </span>
          <span class="text-[13px] leading-[1.55]" style="color:var(--muted);">
            Every query is parsed and rejected unless it's a plain SELECT. Twice.
          </span>
        </div>
        <div
          class="flex flex-col rounded-[20px] border p-5.5"
          style="background:var(--card); border-color:var(--border); gap:8px;"
        >
          <span class="text-[26px] font-extrabold" style="letter-spacing:-0.02em; color:var(--ink);">
            Local-first
          </span>
          <span class="text-[13px] leading-[1.55]" style="color:var(--muted);">
            Knowledge and settings live on your machine. No telemetry, no cloud sync.
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Trust levels bar -->
  <div data-reveal="5"
    class="mt-6 flex flex-wrap items-center rounded-[20px] border p-7"
    style="background:var(--card); border-color:var(--border); gap:32px;"
  >
    <div class="flex min-w-[220px] flex-col" style="gap:6px;">
      <span
        class="text-[11px] tracking-[0.14em]"
        style="font-family:'JetBrains Mono',monospace; color:var(--muted);"
      >
        IT LEARNS YOUR DATABASE
      </span>
      <span class="max-w-[360px] text-[15px] leading-[1.55]" style="color:var(--ink-2);">
        Every answer you confirm teaches it. Trust climbs as you verify.
      </span>
    </div>
    <div class="flex min-w-[320px] flex-1 items-center" style="gap:12px;">
      <div class="flex flex-1 flex-col" style="gap:9px;">
        <div class="h-[5px] rounded-full" style="background:linear-gradient(90deg,var(--border-2),var(--brand));"></div>
        <span class="text-[13px] font-bold" style="color:var(--muted);">Supervised</span>
        <span class="text-xs leading-[1.5]" style="color:var(--faint);">You check everything</span>
      </div>
      <div class="flex flex-1 flex-col" style="gap:9px;">
        <div class="h-[5px] rounded-full" style="background:linear-gradient(90deg,var(--brand),var(--accent));"></div>
        <span class="text-[13px] font-bold" style="color:var(--ink-2);">Assisted</span>
        <span class="text-xs leading-[1.5]" style="color:var(--faint);">It knows your terms</span>
      </div>
      <div class="flex flex-1 flex-col" style="gap:9px;">
        <div class="h-[5px] rounded-full" style="background:linear-gradient(90deg,var(--accent),var(--ok-ink));"></div>
        <span class="text-[13px] font-bold" style="color:var(--ok-ink);">Trusted</span>
        <span class="text-xs leading-[1.5]" style="color:var(--faint);">High confidence, verified</span>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    #trust > div:first-of-type {
      grid-template-columns: 1fr !important;
    }
  }
</style>
