---
const trustLevels = [
  {
    name: 'Supervised',
    desc: 'You check everything',
    bar: 'linear-gradient(90deg,var(--border-2),var(--brand))',
    ink: 'var(--muted)',
  },
  {
    name: 'Assisted',
    desc: 'It knows your terms',
    bar: 'linear-gradient(90deg,var(--brand),var(--accent))',
    ink: 'var(--ink-2)',
  },
  {
    name: 'Trusted',
    desc: 'High confidence, verified',
    bar: 'linear-gradient(90deg,var(--accent),var(--ok-ink))',
    ink: 'var(--ok-ink)',
  },
];
---

<section id="trust" class="bd-trust" data-screen-label="Trust">
  <div class="bd-trust__head" data-reveal="1">
    <span class="bd-eyebrow">03 — TRUST</span>
    <h2 class="bd-h2">Trust you can verify, not vibes.</h2>
  </div>

  <div class="bd-trust__grid">
    <div class="bd-trust__flip-wrap" data-reveal="2">
      <div id="bd-flip-card" class="bd-trust__flip-card">
        <div class="bd-trust__flip-face">
          <span class="bd-trust__flip-label">THE ANSWER YOU SEE</span>
          <div class="bd-trust__flip-answer">
            Revenue this month is <strong class="bd-trust__flip-strong">$284,120</strong> — up 12% on last month.
          </div>
          <div class="bd-trust__flip-explain">
            Summed the order totals of completed orders created this calendar month, compared with the previous
            month.
          </div>
          <div class="bd-trust__flip-footer">
            <button id="bd-flip-btn-1" class="bd-trust__flip-btn" type="button">Show me the SQL ⟲</button>
          </div>
        </div>
        <div class="bd-trust__flip-face bd-trust__flip-face--back">
          <span class="bd-trust__flip-label bd-trust__flip-label--brand">THE SQL UNDERNEATH — ALWAYS ONE TAP AWAY</span>
          <pre class="bd-trust__flip-sql">SELECT SUM(total) AS revenue
FROM orders
WHERE status = 'completed'
  AND created_at &gt;= date_trunc('month', now());</pre>
          <div class="bd-trust__flip-footer">
            <button id="bd-flip-btn-2" class="bd-trust__flip-btn bd-trust__flip-btn--accent" type="button">
              Back to the answer ⟲
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="bd-trust__side">
      <div class="bd-trust__reaches" data-reveal="3">
        <span class="bd-trust__reaches-label">WHAT REACHES THE AI</span>
        <svg viewBox="0 0 320 96" class="bd-trust__diagram" aria-hidden="true">
          <rect x="2" y="26" width="88" height="44" rx="10" fill="none" stroke="var(--border-2)"></rect>
          <text x="46" y="45" text-anchor="middle" fill="var(--ink-2)" font-size="11" font-family="Hanken Grotesk">Your DB</text>
          <text x="46" y="60" text-anchor="middle" fill="var(--faint)" font-size="9" font-family="JetBrains Mono">rows stay here</text>
          <path d="M 96 38 H 218" stroke="var(--brand)" stroke-width="1.5" stroke-dasharray="6 6" class="bd-trust__flow-line"></path>
          <text x="157" y="30" text-anchor="middle" fill="var(--brand)" font-size="9" font-family="JetBrains Mono">schema + question</text>
          <path d="M 96 60 H 150" stroke="#c75d4e" stroke-width="1.5" stroke-dasharray="4 5"></path>
          <text x="123" y="76" text-anchor="middle" fill="var(--low)" font-size="9" font-family="JetBrains Mono">rows ✕ never</text>
          <line x1="146" y1="52" x2="158" y2="68" stroke="#c75d4e" stroke-width="1.5"></line>
          <rect x="224" y="26" width="94" height="44" rx="10" fill="none" stroke="var(--border-2)"></rect>
          <text x="271" y="45" text-anchor="middle" fill="var(--ink-2)" font-size="11" font-family="Hanken Grotesk">Gemini AI</text>
          <text x="271" y="60" text-anchor="middle" fill="var(--faint)" font-size="9" font-family="JetBrains Mono">writes SQL only</text>
        </svg>
        <span class="bd-trust__reaches-body">
          Only your question, the schema, and a few sample values are sent — never bulk table contents, results,
          or credentials.
        </span>
      </div>
      <div class="bd-trust__mini-grid">
        <div class="bd-trust__mini-card">
          <span class="bd-trust__mini-title">Read-only</span>
          <span class="bd-trust__mini-body">Every query is parsed and rejected unless it's a plain SELECT. Twice.</span>
        </div>
        <div class="bd-trust__mini-card">
          <span class="bd-trust__mini-title">Local-first</span>
          <span class="bd-trust__mini-body">Knowledge and settings live on your machine. No telemetry, no cloud sync.</span>
        </div>
      </div>
    </div>
  </div>

  <div class="bd-trust__levels" data-reveal="5">
    <div class="bd-trust__levels-head">
      <span class="bd-trust__reaches-label">IT LEARNS YOUR DATABASE</span>
      <span class="bd-trust__levels-body">Every answer you confirm teaches it. Trust climbs as you verify.</span>
    </div>
    <div class="bd-trust__levels-row">
      {
        trustLevels.map((lv) => (
          <div class="bd-trust__level">
            <div class="bd-trust__level-bar" style={`background:${lv.bar}`} />
            <span class="bd-trust__level-name" style={`color:${lv.ink}`}>
              {lv.name}
            </span>
            <span class="bd-trust__level-desc">{lv.desc}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .bd-trust {
    position: relative;
    z-index: 2;
    max-width: 1060px;
    margin: 0 auto;
    padding: 110px 24px;
  }
  .bd-trust__head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 56px;
  }
  .bd-trust__grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 24px;
    align-items: stretch;
  }
  .bd-trust__flip-wrap {
    perspective: 1400px;
    min-height: 360px;
  }
  .bd-trust__flip-card {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 360px;
    transform-style: preserve-3d;
    transition: transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .bd-trust__flip-card.is-flipped {
    transform: rotateY(180deg);
  }
  .bd-trust__flip-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 30px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .bd-trust__flip-face--back {
    transform: rotateY(180deg);
    background: var(--card-2);
    border-color: var(--border-2);
  }
  .bd-trust__flip-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--muted);
  }
  .bd-trust__flip-label--brand {
    color: var(--brand);
  }
  .bd-trust__flip-answer {
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink);
  }
  .bd-trust__flip-strong {
    color: var(--accent);
  }
  .bd-trust__flip-explain {
    font-size: 14px;
    line-height: 1.55;
    color: var(--muted);
    border-left: 2px solid var(--accent);
    padding-left: 13px;
  }
  .bd-trust__flip-sql {
    margin: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    line-height: 1.7;
    color: var(--ink-2);
    white-space: pre;
    overflow-x: auto;
  }
  .bd-trust__flip-footer {
    margin-top: auto;
  }
  .bd-trust__flip-btn {
    background: transparent;
    border: 1px solid var(--border-2);
    color: var(--ink-2);
    font-size: 13.5px;
    font-weight: 600;
    padding: 10px 18px;
    border-radius: 99px;
    font-family: 'Hanken Grotesk', sans-serif;
    cursor: pointer;
  }
  .bd-trust__flip-btn:hover {
    border-color: var(--brand);
    color: var(--brand);
  }
  .bd-trust__flip-btn--accent:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .bd-trust__side {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .bd-trust__reaches {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 26px 28px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .bd-trust__reaches-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--muted);
  }
  .bd-trust__diagram {
    width: 100%;
    height: auto;
  }
  .bd-trust__flow-line {
    animation: dashFlow 1.2s linear infinite;
  }
  .bd-trust__reaches-body {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--muted);
  }
  .bd-trust__mini-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .bd-trust__mini-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .bd-trust__mini-title {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .bd-trust__mini-body {
    font-size: 13px;
    line-height: 1.55;
    color: var(--muted);
  }
  .bd-trust__levels {
    margin-top: 24px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px 32px;
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .bd-trust__levels-head {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 220px;
  }
  .bd-trust__levels-body {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 360px;
  }
  .bd-trust__levels-row {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 320px;
  }
  .bd-trust__level {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .bd-trust__level-bar {
    height: 5px;
    border-radius: 99px;
  }
  .bd-trust__level-name {
    font-size: 13px;
    font-weight: 700;
  }
  .bd-trust__level-desc {
    font-size: 12px;
    color: var(--faint);
    line-height: 1.5;
  }

  @media (max-width: 860px) {
    .bd-trust__grid {
      grid-template-columns: 1fr;
    }
    .bd-trust__mini-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .bd-trust__levels-head {
      min-width: 0;
    }
    .bd-trust__levels-row {
      min-width: 0;
      width: 100%;
      flex-wrap: wrap;
      gap: 20px;
    }
    .bd-trust__level {
      flex: 1 1 45%;
    }
  }
</style>

<script>
  const card = document.getElementById('bd-flip-card');
  const btn1 = document.getElementById('bd-flip-btn-1');
  const btn2 = document.getElementById('bd-flip-btn-2');
  const toggleFlip = () => card?.classList.toggle('is-flipped');
  btn1?.addEventListener('click', toggleFlip);
  btn2?.addEventListener('click', toggleFlip);
</script>
