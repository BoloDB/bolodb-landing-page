---
const steps = [
  {
    num: 'STEP — 01',
    title: 'Connect',
    body: 'Point BoloDB at any SQL database — the AI is built in, no API keys. About a minute, total.',
  },
  {
    num: 'STEP — 02',
    title: 'Ask',
    body: "Type questions the way you'd ask a colleague. No SQL, no schema spelunking.",
  },
  {
    num: 'STEP — 03',
    title: 'Trust',
    body: 'Every confirmed answer teaches it your database. Accuracy compounds with use.',
  },
];
---

<section
  id="how"
  aria-labelledby="how-title"
  class="relative z-[2] mx-auto max-w-[1060px] px-6 py-[110px]"
>
  <div data-reveal="1" class="mb-[64px] flex flex-col" style="gap:14px;">
    <span
      class="text-xs tracking-[0.22em]"
      style="font-family:'JetBrains Mono',monospace; color:var(--brand);"
    >
      02 — HOW
    </span>
    <h2
      id="how-title"
      class="m-0 max-w-[560px] text-balance font-extrabold leading-[1.05]"
      style="font-size:clamp(2rem,4vw,3.2rem); letter-spacing:-0.03em; color:var(--ink);"
    >
      Three steps. One minute to the first answer.
    </h2>
  </div>

  <div
    class="grid overflow-hidden rounded-[20px] border"
    style="grid-template-columns:repeat(3,1fr); gap:1px; background:var(--border); border-color:var(--border);"
  >
    {steps.map((s, i) => (
      <div data-reveal="2"
        class="flex min-h-[230px] flex-col transition-colors"
        style={{
          background: 'var(--card)',
          gap: '16px',
          padding: '32px 26px 36px',
        }}
        onmouseover="this.style.background='var(--card-hover)'"
        onmouseout="this.style.background='var(--card)'"
      >
        <span
          class="text-xs tracking-[0.1em]"
          style="font-family:'JetBrains Mono',monospace; color:var(--brand);"
        >
          {s.num}
        </span>
        <span
          class="text-xl font-bold"
          style="letter-spacing:-0.015em; color:var(--ink);"
        >
          {s.title}
        </span>
        <span class="text-sm leading-[1.6]" style="color:var(--muted);">
          {s.body}
        </span>
      </div>
    ))}
  </div>
</section>

<style>
  @media (max-width: 768px) {
    div[style*="grid-template-columns:repeat(3,1fr)"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
