---
const steps = [
  {
    num: 'STEP — 01',
    title: 'Connect',
    body: 'Point BoloDB at any SQL database — the AI is built in, no API keys. About a minute, total.',
  },
  {
    num: 'STEP — 02',
    title: 'Ask',
    body: "Type questions the way you'd ask a colleague. No SQL, no schema spelunking.",
  },
  {
    num: 'STEP — 03',
    title: 'Trust',
    body: 'Every confirmed answer teaches it your database. Accuracy compounds with use.',
  },
];
---

<section id="how" class="bd-how" data-screen-label="How it works">
  <div class="bd-how__head" data-reveal="1">
    <span class="bd-eyebrow">02 — HOW</span>
    <h2 class="bd-h2">Three steps. One minute to the first answer.</h2>
  </div>
  <div class="bd-how__grid">
    {
      steps.map((s) => (
        <div class="bd-how__card" data-reveal="2">
          <span class="bd-how__num">{s.num}</span>
          <span class="bd-how__title">{s.title}</span>
          <span class="bd-how__body">{s.body}</span>
        </div>
      ))
    }
  </div>
</section>

<style>
  .bd-how {
    position: relative;
    z-index: 2;
    max-width: 1060px;
    margin: 0 auto;
    padding: 110px 24px;
    scroll-margin-top: 84px;
  }
  .bd-how__head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 64px;
  }
  .bd-how__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
  }
  .bd-how__card {
    background: var(--card);
    padding: 32px 26px 36px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-height: 230px;
    transition:
      background 0.25s,
      transform 0.25s cubic-bezier(0.22, 0.61, 0.36, 1),
      box-shadow 0.25s ease;
  }
  .bd-how__card:hover {
    background: var(--card-hover);
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -24px rgba(var(--glow-rgb), 0.5);
  }
  .bd-how__num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--brand);
    letter-spacing: 0.1em;
  }
  .bd-how__title {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .bd-how__body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .bd-how__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
