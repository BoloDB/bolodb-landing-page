---
const footerLinks = {
  Product: [
    { label: 'Features', href: '#features' },
    { label: 'Pricing', href: '#pricing' },
    { label: 'Open App', href: 'https://app.bolodb.dev' },
  ],
  Resources: [
    { label: 'Documentation', href: 'https://docs.bolodb.dev' },
    { label: 'Blog', href: '/blog' },
    { label: 'Status', href: 'https://status.bolodb.dev' },
  ],
  Company: [
    { label: 'About', href: '/about' },
    { label: 'Contact', href: 'mailto:hello@bolodb.dev' },
  ],
};
---

<footer class="border-t bg-muted/50">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 font-bold text-xl tracking-tight">
          <span class="text-primary">Bolo</span><span>DB</span>
        </a>
        <p class="mt-3 text-sm text-muted-foreground">
          A modern database for your applications.
        </p>
      </div>
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h3 class="mb-3 text-sm font-semibold">{category}</h3>
          <ul class="space-y-2">
            {links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-8 border-t pt-6 text-center text-sm text-muted-foreground">
      &copy; {new Date().getFullYear()} BoloDB. All rights reserved.
    </div>
  </div>
</footer>
