---
---

<footer
  class="relative z-[2] overflow-hidden border-t"
  style="border-color:var(--border); padding:56px 32px 0;"
>
  <div class="mx-auto flex max-w-[1100px] flex-wrap justify-between" style="gap:32px; align-items:flex-start;">
    <!-- Brand -->
    <div class="flex flex-col" style="gap:10px;">
      <span class="text-base font-bold tracking-[-0.02em]" style="color:var(--ink);">
        Bolo<span style="color:var(--brand);">DB</span>
      </span>
      <span class="text-[13px]" style="color:var(--faint);">Ask your data. Trust the answer.</span>
      <span
        class="text-[11px] tracking-[0.08em]"
        style="font-family:'JetBrains Mono',monospace; color:var(--faint);"
      >
        NO TELEMETRY · NO CLOUD SYNC · MIT
      </span>
    </div>

    <!-- Links -->
    <div class="flex flex-wrap" style="gap:56px;">
      <div class="flex flex-col text-[13px]" style="gap:10px;">
        <span
          class="text-[11px] tracking-[0.14em]"
          style="font-family:'JetBrains Mono',monospace; color:var(--faint);"
        >
          PRODUCT
        </span>
        <a href="#demo" style="color:var(--muted);">Demo</a>
        <a href="#features" style="color:var(--muted);">Features</a>
        <a href="#trust" style="color:var(--muted);">Trust</a>
      </div>
      <div class="flex flex-col text-[13px]" style="gap:10px;">
        <span
          class="text-[11px] tracking-[0.14em]"
          style="font-family:'JetBrains Mono',monospace; color:var(--faint);"
        >
          OPEN SOURCE
        </span>
        <a href="https://github.com/BoloDB/bolodb" style="color:var(--muted);">GitHub</a>
        <a href="https://github.com/BoloDB/bolodb/blob/master/docs/README.md" style="color:var(--muted);">Docs</a>
        <a href="https://github.com/BoloDB/bolodb/blob/master/LICENSE" style="color:var(--muted);">MIT License</a>
      </div>
      <div class="flex flex-col text-[13px]" style="gap:10px;">
        <span
          class="text-[11px] tracking-[0.14em]"
          style="font-family:'JetBrains Mono',monospace; color:var(--faint);"
        >
          RESOURCES
        </span>
        <a href="/blog" style="color:var(--muted);">Blog</a>
      </div>
    </div>
  </div>

  <!-- Watermark -->
  <div
   data-dc-tpl="196"
   aria-hidden="true"
    style="display: flex; justify-content: center; margin-top: 48px; pointer-events: none; user-select: none;">
      <span
        data-dc-tpl="197"
        style="font-family: Arial, Helvetica, sans-serif; font-size: clamp(5rem, 17.5vw, 15rem); font-weight: 800; letter-spacing: -0.04em; line-height: 0.78; white-space: nowrap; color: transparent; -webkit-text-stroke: 1.5px var(--wordmark-stroke); transform: translateY(14%); mask-image: linear-gradient(rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.25) 75%, transparent 100%);"
      >
        BoloDB
      </span>
  </div>
</footer>
