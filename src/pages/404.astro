---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | BoloDB" description="The page you're looking for doesn't exist.">
  <section class="flex min-h-[60vh] items-center justify-center">
    <div class="text-center">
      <h1 class="text-6xl font-bold" style="color:var(--ink);">404</h1>
      <p class="mt-4 text-lg" style="color:var(--muted);">Page not found</p>
      <a
        href="/"
        class="mt-8 inline-flex h-10 items-center justify-center rounded-full px-6 text-sm font-bold transition-all"
        style="background:var(--brand); color:var(--on-brand);"
        onmouseover="this.style.background='var(--brand-2)'"
        onmouseout="this.style.background='var(--brand)'"
      >
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
