---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | BoloDB" description="The page you're looking for doesn't exist.">
  <section class="flex min-h-[60vh] items-center justify-center">
    <div class="text-center">
      <h1 class="text-6xl font-bold">404</h1>
      <p class="mt-4 text-lg text-muted-foreground">Page not found</p>
      <a
        href="/"
        class="mt-8 inline-flex h-10 items-center justify-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground hover:bg-primary/90"
      >
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
