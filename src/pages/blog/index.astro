---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog | BoloDB" description="Articles about databases, text-to-SQL, and building trust between humans and AI.">
  <section class="relative z-[2] py-20 md:py-28">
    <div class="mx-auto max-w-[900px] px-6">
      <!-- Header -->
      <div class="mb-14">
        <span
          class="text-xs tracking-[0.22em]"
          style="font-family:'JetBrains Mono',monospace; color:var(--brand);"
        >
          BLOG
        </span>
        <h1
          class="mt-3 text-balance font-extrabold leading-[1.05]"
          style="font-size:clamp(2rem,4vw,3.2rem); letter-spacing:-0.03em; color:var(--ink);"
        >
          Insights & Engineering
        </h1>
        <p class="mt-3 max-w-[480px] text-[15px] leading-[1.65]" style="color:var(--muted);">
          Deep dives on databases, text-to-SQL, privacy-first architecture, and building tools that earn trust.
        </p>
      </div>

      <!-- Post Grid -->
      <div class="grid gap-5" style="grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));">
        {posts.length === 0 && (
          <p class="text-[15px]" style="color:var(--muted);">No posts yet. Check back soon!</p>
        )}
        {posts.map((post, index) => {
          const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });
          return (
            <article class="group">
              <a
                href={`/blog/${post.id}`}
                class="bento-card flex flex-col transition-all"
                style="padding:28px; gap:14px; text-decoration:none; display:flex;"
              >
                <div class="flex items-center gap-3">
                  <time
                    class="text-[11px] tracking-[0.06em]"
                    style="font-family:'JetBrains Mono',monospace; color:var(--faint);"
                  >
                    {formattedDate}
                  </time>
                  {post.data.tags.length > 0 && (
                    <span class="text-[11px]" style="color:var(--border-2);">·</span>
                  )}
                  <div class="flex flex-wrap gap-1.5">
                    {post.data.tags.slice(0, 2).map((tag) => (
                      <span
                        class="rounded px-2 py-0.5 text-[10px] font-semibold tracking-[0.04em]"
                        style="background:rgba(var(--glow-rgb),0.08); color:var(--brand);"
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
                <h2
                  class="text-[18px] font-bold leading-[1.3] transition-colors"
                  style="color:var(--ink); letter-spacing:-0.02em;"
                >
                  {post.data.title}
                </h2>
                <p class="m-0 text-[13.5px] leading-[1.6]" style="color:var(--muted);">
                  {post.data.description}
                </p>
                <div class="mt-auto pt-2">
                  <span
                    class="inline-flex items-center gap-1.5 text-[12px] font-medium transition-colors"
                    style="color:var(--brand);"
                  >
                    Read more
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                      <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                    </svg>
                  </span>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
