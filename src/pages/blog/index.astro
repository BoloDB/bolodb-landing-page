---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog | BoloDB" description="Articles about databases, development, and the BoloDB platform.">
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-4xl px-6">
      <h1 class="text-4xl font-bold tracking-tight" style="color:var(--ink);">Blog</h1>
      <p class="mt-4 text-lg" style="color:var(--muted);">
        Articles about databases, development, and the BoloDB platform.
      </p>

      <div class="mt-12 space-y-8">
        {posts.length === 0 && (
          <p style="color:var(--muted);">No posts yet. Check back soon!</p>
        )}
        {posts.map((post) => {
          const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <article class="group">
              <a
                href={`/blog/${post.id}`}
                class="block rounded-lg border p-6 transition-colors"
                style="border-color:var(--border);"
                onmouseover="this.style.background='var(--surface-2)'"
                onmouseout="this.style.background='transparent'"
              >
                <div class="mb-3 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span
                      class="rounded-full px-2.5 py-0.5 text-xs font-medium"
                      style="background:rgba(var(--glow-rgb),0.15); color:var(--brand);"
                    >
                      {tag}
                    </span>
                  ))}
                </div>
                <h2
                  class="text-xl font-semibold transition-colors"
                  style="color:var(--ink);"
                  onmouseover="this.style.color='var(--brand)'"
                  onmouseout="this.style.color='var(--ink)'"
                >
                  {post.data.title}
                </h2>
                <time class="mt-2 block text-sm" style="color:var(--muted);">{formattedDate}</time>
                <p class="mt-3" style="color:var(--muted);">{post.data.description}</p>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
