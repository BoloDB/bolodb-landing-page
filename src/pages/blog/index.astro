---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog | BoloDB" description="Articles about databases, development, and the BoloDB platform.">
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-4xl px-6">
      <h1 class="text-4xl font-bold tracking-tight">Blog</h1>
      <p class="mt-4 text-lg text-muted-foreground">
        Articles about databases, development, and the BoloDB platform.
      </p>

      <div class="mt-12 space-y-8">
        {posts.length === 0 && (
          <p class="text-muted-foreground">No posts yet. Check back soon!</p>
        )}
        {posts.map((post) => {
          const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <article class="group">
              <a href={`/blog/${post.id}`} class="block rounded-lg border p-6 transition-colors hover:bg-secondary/50">
                <div class="flex flex-wrap gap-2 mb-3">
                  {post.data.tags.map((tag) => (
                    <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
                      {tag}
                    </span>
                  ))}
                </div>
                <h2 class="text-xl font-semibold group-hover:text-primary transition-colors">
                  {post.data.title}
                </h2>
                <time class="mt-2 block text-sm text-muted-foreground">{formattedDate}</time>
                <p class="mt-3 text-muted-foreground">{post.data.description}</p>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
